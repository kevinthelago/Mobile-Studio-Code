{
  "expo": {
    "name": "Mobile Studio Code",
    "slug": "mobile-studio-code",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "mobilestudiocode",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mobilestudiocode.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b0d14"
      },
      "package": "com.mobilestudiocode.app"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
